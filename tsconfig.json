{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,

    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vite/client"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"]
}